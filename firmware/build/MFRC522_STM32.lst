   7:Core/Src/MFRC522_STM32.c ****     USER_LOG("MFRC522 Min Init started");
   8:Core/Src/MFRC522_STM32.c ****     // Hardware reset
   9:Core/Src/MFRC522_STM32.c ****     HAL_GPIO_WritePin(dev->rstPort, dev->rstPin, GPIO_PIN_RESET);
  10:Core/Src/MFRC522_STM32.c ****     HAL_Delay(50);
  11:Core/Src/MFRC522_STM32.c ****     HAL_GPIO_WritePin(dev->rstPort, dev->rstPin, GPIO_PIN_SET);
  12:Core/Src/MFRC522_STM32.c ****     HAL_Delay(50);
  13:Core/Src/MFRC522_STM32.c **** 
  14:Core/Src/MFRC522_STM32.c ****     // Soft reset
  15:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_CommandReg, PCD_SoftReset);
  16:Core/Src/MFRC522_STM32.c ****     HAL_Delay(50);
  17:Core/Src/MFRC522_STM32.c **** 
  18:Core/Src/MFRC522_STM32.c ****     // Clear interrupts
  19:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_ComIrqReg, 0x7F);
  20:Core/Src/MFRC522_STM32.c **** 
  21:Core/Src/MFRC522_STM32.c ****     // Flush FIFO
  22:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_FIFOLevelReg, 0x80);
  23:Core/Src/MFRC522_STM32.c **** 
  24:Core/Src/MFRC522_STM32.c ****     // Timer: ~25ms timeout
  25:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_TModeReg, 0x80);      // Timer starts immediately
  26:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_TPrescalerReg, 0xA9); // 80kHz clock
  27:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_TReloadRegH, 0x03);   // 1000 ticks = ~12.5ms
  28:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_TReloadRegL, 0xE8);
  29:Core/Src/MFRC522_STM32.c **** 
  30:Core/Src/MFRC522_STM32.c ****     // RF settings
  31:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_TxAutoReg, 0x40);     // 100% ASK modulation
ARM GAS  /tmp/ccbCGITS.s 			page 2


  32:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_RFCfgReg, 0x7F);      // Max gain (48dB)
  33:Core/Src/MFRC522_STM32.c ****     MFRC522_WriteReg(dev, PCD_DemodReg, 0x4D);      // Sensitivity for clones
  34:Core/Src/MFRC522_STM32.c **** 
  35:Core/Src/MFRC522_STM32.c ****     // Enable antenna
  36:Core/Src/MFRC522_STM32.c ****     MFRC522_AntennaOn(dev);
  37:Core/Src/MFRC522_STM32.c ****     HAL_Delay(10);  // Let RF stabilize
